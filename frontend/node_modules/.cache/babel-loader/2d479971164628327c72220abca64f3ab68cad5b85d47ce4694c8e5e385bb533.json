{"ast":null,"code":"import{create}from'zustand';let nextId=1;export const useToastStore=create(set=>({toasts:[],push:(type,message)=>{const id=nextId++;set(s=>({toasts:[...s.toasts,{id,type,message}]}));setTimeout(()=>{set(s=>({toasts:s.toasts.filter(t=>t.id!==id)}));},4000);},dismiss:id=>set(s=>({toasts:s.toasts.filter(t=>t.id!==id)}))}));","map":{"version":3,"names":["create","nextId","useToastStore","set","toasts","push","type","message","id","s","setTimeout","filter","t","dismiss"],"sources":["C:/archive/projects/leg_proj3/frontend/src/store/toastStore.js"],"sourcesContent":["import { create } from 'zustand';\r\n\r\nlet nextId = 1;\r\n\r\nexport const useToastStore = create((set) => ({\r\n  toasts: [],\r\n  push: (type, message) => {\r\n    const id = nextId++;\r\n    set((s) => ({ toasts: [...s.toasts, { id, type, message }] }));\r\n    setTimeout(() => {\r\n      set((s) => ({ toasts: s.toasts.filter((t) => t.id !== id) }));\r\n    }, 4000);\r\n  },\r\n  dismiss: (id) => set((s) => ({ toasts: s.toasts.filter((t) => t.id !== id) })),\r\n}));\r\n"],"mappings":"AAAA,OAASA,MAAM,KAAQ,SAAS,CAEhC,GAAI,CAAAC,MAAM,CAAG,CAAC,CAEd,MAAO,MAAM,CAAAC,aAAa,CAAGF,MAAM,CAAEG,GAAG,GAAM,CAC5CC,MAAM,CAAE,EAAE,CACVC,IAAI,CAAEA,CAACC,IAAI,CAAEC,OAAO,GAAK,CACvB,KAAM,CAAAC,EAAE,CAAGP,MAAM,EAAE,CACnBE,GAAG,CAAEM,CAAC,GAAM,CAAEL,MAAM,CAAE,CAAC,GAAGK,CAAC,CAACL,MAAM,CAAE,CAAEI,EAAE,CAAEF,IAAI,CAAEC,OAAQ,CAAC,CAAE,CAAC,CAAC,CAAC,CAC9DG,UAAU,CAAC,IAAM,CACfP,GAAG,CAAEM,CAAC,GAAM,CAAEL,MAAM,CAAEK,CAAC,CAACL,MAAM,CAACO,MAAM,CAAEC,CAAC,EAAKA,CAAC,CAACJ,EAAE,GAAKA,EAAE,CAAE,CAAC,CAAC,CAAC,CAC/D,CAAC,CAAE,IAAI,CAAC,CACV,CAAC,CACDK,OAAO,CAAGL,EAAE,EAAKL,GAAG,CAAEM,CAAC,GAAM,CAAEL,MAAM,CAAEK,CAAC,CAACL,MAAM,CAACO,MAAM,CAAEC,CAAC,EAAKA,CAAC,CAACJ,EAAE,GAAKA,EAAE,CAAE,CAAC,CAAC,CAC/E,CAAC,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}