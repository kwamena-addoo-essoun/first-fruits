# Copy this file to .env and fill in the values before running the server.

# Required — change this to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this

# Optional — defaults to SQLite if not set.
# Set to a PostgreSQL URL for production, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/time_tracker
DATABASE_URL=sqlite:///./time_tracker.db

# Comma-separated list of allowed CORS origins.
# For production, set this to your exact frontend URL(s), e.g.:
# ALLOWED_ORIGINS=https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL — used in email links and Stripe redirect URLs.
FRONTEND_URL=http://localhost:3000

# ── Email / SMTP (optional — required for email features) ────────────────────
# Example using Gmail App Password:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ── Stripe (optional — required for paid subscriptions) ──────────────────────
# 1. Create a product + recurring price in the Stripe Dashboard
# 2. Copy the Price ID (price_xxx) into STRIPE_PRO_PRICE_ID
# 3. Set up a webhook endpoint pointing to /api/billing/webhook
#    and add the signing secret below.
# Test keys start with sk_test_ / pk_test_
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
