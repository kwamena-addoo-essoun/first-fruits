# Copy this file to .env and fill in the values before running the server.

# Required — change this to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this

# Optional — defaults to SQLite if not set.
# Set to a PostgreSQL URL for production, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/time_tracker
DATABASE_URL=sqlite:///./time_tracker.db

# Comma-separated list of allowed CORS origins.
# For production, set this to your exact frontend URL(s), e.g.:
# ALLOWED_ORIGINS=https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
